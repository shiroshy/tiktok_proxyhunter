<Window x:Class="TikTokProxyHunter.Desktop.Views.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:models="clr-namespace:TikTokProxyHunter.Desktop.Models" Title="TikTok Proxy Hunter" MinWidth="1024" MinHeight="720" Width="1360" Height="820" WindowStartupLocation="CenterScreen" Style="{StaticResource {x:Type Window}}">
  <Window.InputBindings>
    <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewSearchCommand}"/><KeyBinding Key="R" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Results"/><KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportCommand}"/><KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Settings"/><KeyBinding Key="L" Modifiers="Control" Command="{Binding NavigateCommand}" CommandParameter="Diagnostics"/><KeyBinding Key="F5" Command="{Binding RefreshCommand}"/><KeyBinding Key="Escape" Command="{Binding EscapeCommand}"/>
  </Window.InputBindings>
  <Grid><Grid.RowDefinitions><RowDefinition Height="64"/><RowDefinition Height="*"/><RowDefinition Height="38"/></Grid.RowDefinitions>
    <Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"><Grid Margin="18,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Viewbox Width="32" Height="32" Margin="0,0,12,0"><Canvas Width="32" Height="32"><Path Fill="{DynamicResource AccentBrush}" Data="M16,2 L28,7 V15 C28,23 23,28 16,31 C9,28 4,23 4,15 V7 Z"/><Path Stroke="#102228" StrokeThickness="2" Data="M10,16 L14,20 L23,11"/></Canvas></Viewbox><TextBlock Text="TikTok Proxy Hunter" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding RunStatus}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/></Grid></Border>
    <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="{Binding NavigationWidth}"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"><DockPanel><Button DockPanel.Dock="Bottom" Command="{Binding ToggleNavigationCommand}" Margin="12" ToolTip="Компактный режим навигации"><TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" AutomationProperties.Name="Свернуть меню"/></Button><ItemsControl ItemsSource="{Binding NavigationItems}" Margin="8,12"><ItemsControl.ItemTemplate><DataTemplate DataType="{x:Type models:NavigationItem}"><Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Key}" ToolTip="{Binding ToolTip}" HorizontalContentAlignment="Left" Margin="0,2" Padding="12,10"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="17" Width="28" AutomationProperties.Name="{Binding ToolTip}"/><TextBlock Text="{Binding Title}" Visibility="{Binding DataContext.AreNavigationLabelsVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}" VerticalAlignment="Center"/></StackPanel></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></DockPanel></Border>
      <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="0" Focusable="False"/>
    </Grid>
    <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"><Grid Margin="16,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding CurrentStage}" VerticalAlignment="Center"/><TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"><Run Text="TikTok доступен: "/><Run Text="{Binding WorkingCount}"/><Run Text="  ·  Время: "/><Run Text="{Binding Elapsed, StringFormat={}{0:hh\\:mm\\:ss}}"/></TextBlock></Grid></Border>
  </Grid>
</Window>
