<UserControl x:Class="TikTokProxyHunter.Desktop.Views.DashboardView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="38" MaxWidth="1120" HorizontalAlignment="Left">
  <Border Style="{StaticResource Card}" Padding="30"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Найти рабочий прокси для TikTok" Style="{StaticResource PageTitle}"/><TextBlock Text="Программа соберёт публичные прокси, проверит доступ к TikTok, исключит российские выходные IP и покажет лучшие результаты." Style="{StaticResource SecondaryText}" TextWrapping="Wrap" MaxWidth="720" Margin="0,10,0,22"/><StackPanel Orientation="Horizontal"><Button Content="Начать быстрый поиск" Style="{StaticResource PrimaryButton}" Command="{Binding StartQuickSearchCommand}" Margin="0,0,10,0" AutomationProperties.Name="Начать быстрый поиск"/><Button Content="Настроить поиск" Command="{Binding ConfigureSearchCommand}" Margin="0,0,10,0"/><Button Content="Продолжить последний запуск" Command="{Binding ContinueCommand}"/></StackPanel></StackPanel></Grid></Border>
  <TextBlock Text="Последний результат" Style="{StaticResource SectionTitle}" Margin="0,28,0,12"/><UniformGrid Columns="6"><Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="{Binding Candidates}" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Кандидатов" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="{Binding Working}" FontSize="24"/><TextBlock Text="Рабочих" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="{Binding TikTokAccessible}" FontSize="24"/><TextBlock Text="TikTok доступен" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="{Binding Stable}" FontSize="24"/><TextBlock Text="Стабильных" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="{Binding PlaybackVerified}" FontSize="24"/><TextBlock Text="Видео" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="{Binding Recommended}" FontSize="24" Foreground="{DynamicResource SuccessBrush}"/><TextBlock Text="Рекомендовано" Style="{StaticResource SecondaryText}"/></StackPanel></Border></UniformGrid>
  <Border Style="{StaticResource Card}" Margin="0,24,0,0"><StackPanel><TextBlock Text="Лучший найденный прокси" Style="{StaticResource SectionTitle}"/><TextBlock Text="{Binding BestProxy.Address, TargetNullValue=Пока нет проверенного результата}" FontSize="24" Margin="0,10,0,4"/><TextBlock Text="{Binding BestProxy.SummaryLine}" Style="{StaticResource SecondaryText}"/><StackPanel Orientation="Horizontal" Margin="0,16,0,0"><Button Content="Копировать" Command="{Binding CopyBestCommand}" Margin="0,0,8,0"/><Button Content="Подробнее" Command="{Binding OpenBestCommand}"/></StackPanel></StackPanel></Border>
 </StackPanel></ScrollViewer>
</UserControl>
