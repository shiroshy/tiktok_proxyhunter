<UserControl x:Class="TikTokProxyHunter.Desktop.Views.ProxyDetailsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="38"><DockPanel><Button Content="← Назад" Command="{Binding BackCommand}" Margin="0,0,16,0"/><StackPanel><TextBlock Text="{Binding Result.Address}" Style="{StaticResource PageTitle}"/><TextBlock Text="{Binding Result.SummaryLine}" Style="{StaticResource SecondaryText}"/></StackPanel><Button DockPanel.Dock="Right" Content="Копировать" Command="{Binding CopyCommand}"/></DockPanel>
  <UniformGrid Columns="2" Margin="0,24,0,0"><Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Общая информация" Style="{StaticResource SectionTitle}"/><TextBlock Margin="0,10,0,0"><Run Text="Протокол: "/><Run Text="{Binding Result.ProtocolLabel, Mode=OneWay}"/></TextBlock><TextBlock><Run Text="Score: "/><Run Text="{Binding Result.Score, Mode=OneWay}"/></TextBlock><TextBlock><Run Text="Класс: "/><Run Text="{Binding Result.ClassLabel, Mode=OneWay}"/></TextBlock><TextBlock><Run Text="Источник-семейств: "/><Run Text="{Binding Result.SourceFamilyCount, Mode=OneWay}"/></TextBlock></StackPanel></Border><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Выходной IP" Style="{StaticResource SectionTitle}"/><TextBlock Margin="0,10,0,0"><Run Text="IP: "/><Run Text="{Binding Result.ExitIp, Mode=OneWay}"/></TextBlock><TextBlock><Run Text="Страна: "/><Run Text="{Binding Result.Country, Mode=OneWay}"/></TextBlock><TextBlock><Run Text="Geo confidence: "/><Run Text="{Binding Result.GeoConfidence, Mode=OneWay}"/></TextBlock><TextBlock><Run Text="ASN: "/><Run Text="{Binding Result.Asn, Mode=OneWay}"/></TextBlock></StackPanel></Border></UniformGrid>
  <TextBlock Text="Доступ к TikTok" Style="{StaticResource SectionTitle}" Margin="0,26,0,10"/><ItemsControl ItemsSource="{Binding Capabilities}"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,6"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Name}"/><TextBlock Grid.Column="1" Text="{Binding Status}" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="{Binding Reason}" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Column="3" Text="{Binding LatencyMs, StringFormat={}{0:N0} ms}" HorizontalAlignment="Right"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
  <TextBlock Text="Почему такой результат" Style="{StaticResource SectionTitle}" Margin="0,26,0,10"/><Border Style="{StaticResource Card}"><TextBlock Text="{Binding Explanation}" TextWrapping="Wrap"/></Border>
 </StackPanel></ScrollViewer>
</UserControl>
