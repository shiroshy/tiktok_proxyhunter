<UserControl x:Class="TikTokProxyHunter.Desktop.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="38" MaxWidth="980" HorizontalAlignment="Left"><DockPanel><TextBlock Text="Настройки" Style="{StaticResource PageTitle}"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Вернуть безопасные настройки" Command="{Binding ResetCommand}" Margin="0,0,8,0"/><Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}"/></StackPanel></DockPanel>
  <UniformGrid Columns="2" Margin="0,22,0,0"><Border Style="{StaticResource Card}" Margin="0,0,8,8"><StackPanel><TextBlock Text="Основные" Style="{StaticResource SectionTitle}"/><TextBlock Text="Тема" Margin="0,12,0,5"/><ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}"/><TextBlock Text="Папка результатов" Margin="0,12,0,5"/><TextBox Text="{Binding OutputDirectory}"/><TextBlock Text="Кандидатов по умолчанию" Margin="0,12,0,5"/><TextBox Text="{Binding DefaultCandidates}"/><CheckBox Content="Автоматически открывать результаты" IsChecked="{Binding AutoOpenResults}"/><Button Content="Повторить первичную настройку" Command="{Binding RepeatOnboardingCommand}" HorizontalAlignment="Left" Margin="0,12,0,0"/></StackPanel></Border>
  <Border Style="{StaticResource Card}" Margin="0,0,0,8"><StackPanel><TextBlock Text="Проверка" Style="{StaticResource SectionTitle}"/><TextBlock Text="Concurrency" Margin="0,12,0,5"/><TextBox Text="{Binding Concurrency}"/><TextBlock Text="Timeout, секунд" Margin="0,12,0,5"/><TextBox Text="{Binding TimeoutSeconds}"/><CheckBox Content="Разрешать unknown geo для технической проверки" IsChecked="{Binding AllowUnknownGeo}"/><CheckBox Content="Отклонять likely RU" IsChecked="{Binding RejectLikelyRussia}"/><TextBlock Text="Минимальная geo-достоверность для рекомендации" Margin="0,8,0,5"/><ComboBox ItemsSource="{Binding GeoConfidenceLevels}" SelectedItem="{Binding MinimumGeoConfidence}"/><TextBlock Text="Попыток stability"/><TextBox Text="{Binding StabilityAttempts}"/></StackPanel></Border>
  <Border Style="{StaticResource Card}" Margin="0,0,8,8"><StackPanel><TextBlock Text="TikTok-видео" Style="{StaticResource SectionTitle}"/><ItemsControl ItemsSource="{Binding VideoUrls}" Margin="0,10"><ItemsControl.ItemTemplate><DataTemplate><DockPanel Margin="0,2"><Button Content="Удалить" DockPanel.Dock="Right" Command="{Binding DataContext.RemoveVideoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/><TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/></DockPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><DockPanel><Button Content="Добавить" DockPanel.Dock="Right" Command="{Binding AddVideoCommand}" Margin="8,0,0,0"/><TextBox Text="{Binding NewVideoUrl}"/></DockPanel></StackPanel></Border>
  <Border Style="{StaticResource Card}" Margin="0,0,0,8"><StackPanel><TextBlock Text="GeoIP" Style="{StaticResource SectionTitle}"/><TextBlock Text="Country MMDB" Margin="0,10,0,5"/><DockPanel><Button Content="…" DockPanel.Dock="Right" Command="{Binding PickCountryDbCommand}"/><TextBox Text="{Binding CountryDatabasePath}"/></DockPanel><TextBlock Text="ASN MMDB" Margin="0,10,0,5"/><DockPanel><Button Content="…" DockPanel.Dock="Right" Command="{Binding PickAsnDbCommand}"/><TextBox Text="{Binding AsnDatabasePath}"/></DockPanel><Button Content="Проверить базы" Command="{Binding ValidateGeoCommand}" HorizontalAlignment="Left" Margin="0,10,0,0"/><TextBlock Text="{Binding GeoState}" Style="{StaticResource SecondaryText}" TextWrapping="Wrap"/></StackPanel></Border>
  <Border Style="{StaticResource Card}" Margin="0,0,8,8"><StackPanel><TextBlock Text="Браузер" Style="{StaticResource SectionTitle}"/><TextBlock Text="{Binding BrowserState}" TextWrapping="Wrap" Margin="0,10"/><StackPanel Orientation="Horizontal"><Button Content="Проверить браузер" Command="{Binding BrowserDoctorCommand}" Margin="0,0,8,0"/><Button Content="Установить Chromium" Command="{Binding InstallChromiumCommand}"/></StackPanel><TextBlock Text="Browser limit" Margin="0,12,0,5"/><TextBox Text="{Binding BrowserLimit}"/><CheckBox Content="Скриншоты только при ошибке" IsChecked="{Binding CaptureScreenshots}"/></StackPanel></Border>
  <Border Style="{StaticResource Card}" Margin="0,0,0,8"><StackPanel><TextBlock Text="Источники" Style="{StaticResource SectionTitle}"/><TextBlock Text="Путь к proxy-sources.json" Margin="0,10,0,5"/><TextBox Text="{Binding SourcesPath}"/><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Content="Найти новые через GitHub API" Command="{Binding DiscoverSourcesCommand}" Margin="0,0,8,0"/><Button Content="Dry-run import" Command="{Binding PreviewImportCommand}"/></StackPanel><TextBlock Text="Найденные definitions сохраняются выключенными и требуют ручного просмотра." Style="{StaticResource SecondaryText}" TextWrapping="Wrap" Margin="0,10,0,0"/><TextBlock Text="{Binding SourceOperationState}" TextWrapping="Wrap" Margin="0,6,0,0"/></StackPanel></Border></UniformGrid>
  <TextBlock Text="{Binding SaveState}" Foreground="{DynamicResource SuccessBrush}" Margin="0,8"/>
 </StackPanel></ScrollViewer>
</UserControl>
