<Window x:Class="TikTokProxyHunter.Desktop.Views.QuickScanWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Быстрый поиск" Width="600" Height="650" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Style="{StaticResource {x:Type Window}}">
  <Grid Margin="28"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel><TextBlock Text="Найти рабочий прокси" Style="{StaticResource PageTitle}"/><TextBlock Text="Выберите глубину и дополнительные проверки." Style="{StaticResource SecondaryText}" Margin="0,6,0,20"/></StackPanel>
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel>
      <TextBlock Text="Количество кандидатов" FontWeight="SemiBold" Margin="0,0,0,8"/>
      <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding Preset}" AutomationProperties.Name="Глубина поиска"/>
      <TextBlock Text="Лимит" Margin="0,14,0,6"/><TextBox Text="{Binding CustomLimit, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Количество кандидатов"/>
      <CheckBox Content="Проверять публичное видео" IsChecked="{Binding CheckPublicVideo}" Margin="0,18,0,4"/>
      <TextBlock Text="URL публичного TikTok-видео"/><TextBox Text="{Binding PublicVideoUrl, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CheckPublicVideo}" Margin="0,6"/>
      <CheckBox Content="Проверять воспроизведение в браузере" IsChecked="{Binding BrowserVerification}" IsEnabled="{Binding CheckPublicVideo}"/>
      <CheckBox Content="Разрешать неизвестную страну для технической проверки" IsChecked="{Binding AllowUnknownGeo}" Margin="0,10"/>
      <Border Style="{StaticResource Card}" BorderBrush="{DynamicResource WarningBrush}" Margin="0,14,0,0"><TextBlock TextWrapping="Wrap" Text="Публичные прокси нестабильны и потенциально небезопасны. Не вводите через них пароли и не используйте основной аккаунт до ручной проверки."/></Border>
      <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,10"/>
    </StackPanel></ScrollViewer>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0"><Button Content="Расширенные настройки" Click="Advanced_Click" Margin="0,0,10,0"/><Button Content="Отмена" IsCancel="True" Margin="0,0,10,0"/><Button Content="Начать" Style="{StaticResource PrimaryButton}" Click="Start_Click" IsEnabled="{Binding IsValid}"/></StackPanel>
  </Grid>
</Window>
