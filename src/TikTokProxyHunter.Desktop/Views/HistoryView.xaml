<UserControl x:Class="TikTokProxyHunter.Desktop.Views.HistoryView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Margin="30">
  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
  <DockPanel>
   <TextBlock Text="История запусков" Style="{StaticResource PageTitle}"/>
   <Button DockPanel.Dock="Right" Content="Обновить" Command="{Binding RefreshCommand}"/>
  </DockPanel>
  <Grid Grid.Row="1" Margin="0,18,0,0">
   <ListBox ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRun}" Background="Transparent"
            BorderThickness="0" ScrollViewer.CanContentScroll="True">
    <ListBox.ItemTemplate>
     <DataTemplate>
      <Border Style="{StaticResource Card}" Margin="0,0,0,9" Width="760">
       <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel>
         <TextBlock Text="{Binding StartedAt, StringFormat={}{0:dd MMMM yyyy, HH:mm}}" FontSize="18" FontWeight="SemiBold"/>
         <TextBlock Margin="0,7,0,0">
          <Run Text="Кандидатов: "/><Run Text="{Binding Summary.Unique, Mode=OneWay}"/>
          <Run Text=" · TikTok: "/><Run Text="{Binding Summary.TikTokAccessible, Mode=OneWay}"/>
          <Run Text=" · стабильных: "/><Run Text="{Binding Summary.Stable, Mode=OneWay}"/>
          <Run Text=" · playback: "/><Run Text="{Binding Summary.PlaybackVerified, Mode=OneWay}"/>
         </TextBlock>
         <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource SecondaryText}" Margin="0,5,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
         <Button Content="Результаты" Command="{Binding DataContext.OpenResultsCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Margin="0,0,6,0"/>
         <Button Content="Продолжить" Command="{Binding DataContext.ResumeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Margin="0,0,6,0"/>
         <Button Content="Папка" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
        </StackPanel>
       </Grid>
      </Border>
     </DataTemplate>
    </ListBox.ItemTemplate>
   </ListBox>
   <TextBlock Text="{Binding EmptyMessage}" Style="{StaticResource SecondaryText}" HorizontalAlignment="Center"
              VerticalAlignment="Center" FontSize="18" IsHitTestVisible="False"/>
  </Grid>
 </Grid>
</UserControl>
