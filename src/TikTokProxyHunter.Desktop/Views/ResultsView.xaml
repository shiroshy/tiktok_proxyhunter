<UserControl x:Class="TikTokProxyHunter.Desktop.Views.ResultsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <Grid Margin="30"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <DockPanel><TextBlock Text="{Binding RunTitle}" Style="{StaticResource PageTitle}"/><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Экспортировать" Command="{Binding ExportCommand}" Margin="0,0,8,0"/><Button Content="Проверить выбранные" Command="{Binding RecheckCommand}" Margin="0,0,8,0"/><Button Content="Открыть папку" Command="{Binding OpenFolderCommand}"/></StackPanel></DockPanel>
  <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,18,0,12" Padding="12"><WrapPanel><ComboBox Width="190" ItemsSource="{Binding ClassFilters}" SelectedItem="{Binding ClassFilter}" Margin="0,0,8,0"/><ComboBox Width="145" ItemsSource="{Binding ProtocolFilters}" SelectedItem="{Binding ProtocolFilter}" Margin="0,0,8,0"/><TextBox Width="130" Text="{Binding CountryFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Страна" Margin="0,0,8,0"/><TextBox Width="270" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="IP, страна, ASN или источник" Margin="0,0,8,0"/><CheckBox Content="Только без credentials" IsChecked="{Binding CredentialsFreeOnly}"/></WrapPanel></Border>
  <DataGrid Grid.Row="2" ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}" IsReadOnly="True" AutoGenerateColumns="False" MouseDoubleClick="Grid_DoubleClick" AutomationProperties.Name="Результаты прокси"><DataGrid.Columns>
   <DataGridCheckBoxColumn Header="★" Binding="{Binding IsFavorite}"/><DataGridTextColumn Header="Адрес" Binding="{Binding Address, Mode=OneWay}" Width="170"/><DataGridTextColumn Header="Протокол" Binding="{Binding ProtocolLabel, Mode=OneWay}" Width="120"/><DataGridTextColumn Header="Страна" Binding="{Binding Country, Mode=OneWay}" Width="90"/><DataGridTextColumn Header="TikTok" Binding="{Binding TikTokStatus, Mode=OneWay}" Width="170"/><DataGridTextColumn Header="Видео" Binding="{Binding PlaybackStatus, Mode=OneWay}" Width="170"/><DataGridTextColumn Header="Стабильность" Binding="{Binding StabilityText, Mode=OneWay}" Width="120"/><DataGridTextColumn Header="Задержка" Binding="{Binding LatencyText, Mode=OneWay}" Width="100"/><DataGridTextColumn Header="Score" Binding="{Binding Score, Mode=OneWay}" Width="70"/><DataGridTextColumn Header="Последняя проверка" Binding="{Binding LastChecked, Mode=OneWay, StringFormat={}{0:dd.MM HH:mm}}" Width="125"/>
  </DataGrid.Columns><DataGrid.ContextMenu><ContextMenu><MenuItem Header="Копировать proxy URL" Command="{Binding PlacementTarget.DataContext.CopyProxyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/><MenuItem Header="Копировать IP:PORT" Command="{Binding PlacementTarget.DataContext.CopyEndpointCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/><Separator/><MenuItem Header="Проверить снова" Command="{Binding PlacementTarget.DataContext.RecheckCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/><MenuItem Header="Открыть подробности" Command="{Binding PlacementTarget.DataContext.OpenDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/><MenuItem Header="Добавить/убрать избранное" Command="{Binding PlacementTarget.DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/></ContextMenu></DataGrid.ContextMenu></DataGrid>
  <DockPanel Grid.Row="3" Margin="0,10,0,0"><TextBlock Text="{Binding FilteredCount, StringFormat=Найдено: {0:N0}}" Style="{StaticResource SecondaryText}"/><Button DockPanel.Dock="Right" Content="Показать ещё" Command="{Binding LoadMoreCommand}"/></DockPanel>
 </Grid>
</UserControl>
