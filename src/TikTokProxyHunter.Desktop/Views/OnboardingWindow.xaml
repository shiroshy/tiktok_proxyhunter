<Window x:Class="TikTokProxyHunter.Desktop.Views.OnboardingWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Добро пожаловать" Width="720" Height="520" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Style="{StaticResource {x:Type Window}}">
  <Grid Margin="42"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid>
      <StackPanel Visibility="{Binding Page, Converter={StaticResource PageZeroVisibility}}" VerticalAlignment="Center"><TextBlock Text="TikTok Proxy Hunter" Style="{StaticResource PageTitle}" FontSize="34"/><TextBlock Text="Ищет публичные прокси и проверяет, открывается ли через них TikTok." FontSize="18" TextWrapping="Wrap" Margin="0,18"/></StackPanel>
      <StackPanel Visibility="{Binding Page, Converter={StaticResource PageOneVisibility}}" VerticalAlignment="Center"><TextBlock Text="Безопасность прежде всего" Style="{StaticResource PageTitle}"/><TextBlock Text="Бесплатные прокси могут быть медленными, небезопасными и быстро переставать работать.&#10;&#10;Не вводите через них пароли." FontSize="18" TextWrapping="Wrap" Margin="0,18"/></StackPanel>
      <StackPanel Visibility="{Binding Page, Converter={StaticResource PageTwoVisibility}}"><TextBlock Text="Проверка окружения" Style="{StaticResource PageTitle}"/><TextBlock Text="{Binding EnvironmentState}" TextWrapping="Wrap" Margin="0,18"/><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Chromium" FontWeight="SemiBold"/><TextBlock Text="{Binding ChromiumState}" Margin="0,5,0,12"/><Button Content="Установить Chromium" Command="{Binding InstallChromiumCommand}" HorizontalAlignment="Left"/></StackPanel></Border></StackPanel>
    </Grid>
    <DockPanel Grid.Row="1" Margin="0,24,0,0"><Button Content="Назад" Command="{Binding PreviousCommand}" DockPanel.Dock="Left"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Далее" Command="{Binding NextCommand}" Margin="0,0,10,0"/><Button Content="Начать работу" Style="{StaticResource PrimaryButton}" Click="Finish_Click" Visibility="{Binding Page, Converter={StaticResource PageTwoVisibility}}"/></StackPanel></DockPanel>
  </Grid>
</Window>
