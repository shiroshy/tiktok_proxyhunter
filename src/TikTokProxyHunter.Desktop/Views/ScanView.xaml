<UserControl x:Class="TikTokProxyHunter.Desktop.Views.ScanView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="38"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Поиск прокси" Style="{StaticResource PageTitle}"/><TextBlock Text="{Binding StartedAt, StringFormat=Запуск начат: {0:dd MMMM yyyy, HH:mm}}" Style="{StaticResource SecondaryText}"/></StackPanel><Button Grid.Column="1" Content="Отменить" Style="{StaticResource DangerButton}" Command="{Binding CancelCommand}" VerticalAlignment="Top"/></Grid>
  <Border Style="{StaticResource Card}" Margin="0,24,0,18"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding CurrentStage}" Style="{StaticResource SectionTitle}" Margin="0,0,16,0"/><TextBlock Grid.Column="1" Text="{Binding CurrentStageProgress}" VerticalAlignment="Center"/></Grid><ProgressBar Value="{Binding OverallProgress}" IsIndeterminate="{Binding IsIndeterminate}" Margin="0,12"/><TextBlock Text="{Binding StatusLabel}" Style="{StaticResource SecondaryText}"/></StackPanel></Border>
  <UniformGrid Columns="7"><Border Style="{StaticResource Card}" Margin="0,0,6,0"><StackPanel><TextBlock Text="{Binding Collected}" FontSize="20"/><TextBlock Text="Собрано" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,6,0"><StackPanel><TextBlock Text="{Binding Unique}" FontSize="20"/><TextBlock Text="Уникальных" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,6,0"><StackPanel><TextBlock Text="{Binding ProtocolAlive}" FontSize="20"/><TextBlock Text="Живых" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,6,0"><StackPanel><TextBlock Text="{Binding GenericHttps}" FontSize="20"/><TextBlock Text="HTTPS" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,6,0"><StackPanel><TextBlock Text="{Binding TikTokAccessible}" FontSize="20"/><TextBlock Text="TikTok" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,0,6,0"><StackPanel><TextBlock Text="{Binding Stable}" FontSize="20"/><TextBlock Text="Стабильных" Style="{StaticResource SecondaryText}"/></StackPanel></Border><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="{Binding RejectedRussia}" FontSize="20"/><TextBlock Text="RU исключено" Style="{StaticResource SecondaryText}"/></StackPanel></Border></UniformGrid>
  <ItemsControl ItemsSource="{Binding Stages}" Margin="0,24,0,0"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,6"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding StatusLabel}" Margin="0,0,14,0"/><TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,16,0"/><TextBlock Grid.Column="2"><Run Text="{Binding Processed, Mode=OneWay}"/><Run Text=" · прошло "/><Run Text="{Binding Passed, Mode=OneWay}"/><Run Text=" · отклонено "/><Run Text="{Binding Rejected, Mode=OneWay}"/></TextBlock></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
 </StackPanel></ScrollViewer>
</UserControl>
